<?xml version="1.0" encoding="utf-8"?>
<jtlshopplugin>
    <Name>BBF Filialfinder</Name>
    <Description>Das JTL-Shop Plugin "BBF Filialfinder" ermöglicht die Verwaltung und Darstellung von Filialstandorten mit interaktiver Kartenintegration, Öffnungszeiten-Management, Umkreissuche und DSGVO-konformem Consent-Management.</Description>
    <Author>bbfdesign.de</Author>
    <URL>https://www.bbfdesign.de</URL>
    <PluginID>bbfdesign_filialfinder</PluginID>
    <XMLVersion>100</XMLVersion>
    <MinShopVersion>5.5.0</MinShopVersion>
    <Icon>fa-map-marker-alt</Icon>
    <Version>1.2.0</Version>
    <CreateDate>2026-03-19</CreateDate>
    <Install>
        <ServicesRequiringConsent>
            <Vendor>
                <ID>bbf_filialfinder_osm</ID>
                <Company>OpenStreetMap Foundation</Company>
                <Localization iso="GER">
                    <Name>OpenStreetMap</Name>
                    <Purpose>Kartenanzeige</Purpose>
                    <Description>OpenStreetMap wird verwendet, um interaktive Karten mit Filialstandorten anzuzeigen. Dabei werden Kartendaten von externen Tile-Servern geladen.</Description>
                    <PrivacyPolicy>https://wiki.osmfoundation.org/wiki/Privacy_Policy</PrivacyPolicy>
                </Localization>
                <Localization iso="ENG">
                    <Name>OpenStreetMap</Name>
                    <Purpose>Map Display</Purpose>
                    <Description>OpenStreetMap is used to display interactive maps with store locations. Map data is loaded from external tile servers.</Description>
                    <PrivacyPolicy>https://wiki.osmfoundation.org/wiki/Privacy_Policy</PrivacyPolicy>
                </Localization>
            </Vendor>
            <Vendor>
                <ID>bbf_filialfinder_google</ID>
                <Company>Google LLC</Company>
                <Localization iso="GER">
                    <Name>Google Maps</Name>
                    <Purpose>Kartenanzeige</Purpose>
                    <Description>Google Maps wird verwendet, um interaktive Karten mit Filialstandorten anzuzeigen. Dabei werden Daten an Google uebermittelt.</Description>
                    <PrivacyPolicy>https://policies.google.com/privacy</PrivacyPolicy>
                </Localization>
                <Localization iso="ENG">
                    <Name>Google Maps</Name>
                    <Purpose>Map Display</Purpose>
                    <Description>Google Maps is used to display interactive maps with store locations. Data is transmitted to Google.</Description>
                    <PrivacyPolicy>https://policies.google.com/privacy</PrivacyPolicy>
                </Localization>
            </Vendor>
        </ServicesRequiringConsent>
        <Portlets>
            <Portlet>
                <Title>BBF Filialfinder</Title>
                <Class>BbfFilialfinder</Class>
                <Group>content</Group>
                <Active>1</Active>
            </Portlet>
        </Portlets>
        <Adminmenu>
            <Customlink sort="1">
                <Name>Filialfinder</Name>
                <Filename>index.tpl</Filename>
            </Customlink>
        </Adminmenu>
